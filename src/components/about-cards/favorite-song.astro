---
import { getLangFromUrl, useTranslations } from "@/i18n/utils"
import { FAKE_MASONRY_ITEM_ID } from "@/constants/ids"
import FakeMasonryItem from "@/components/fake-masonry-item.astro"
import FavoriteSongCard from "@/components/favorite-song-card.astro"

const locale = getLangFromUrl(Astro.url)
const t = useTranslations(locale)
---

<FakeMasonryItem id={FAKE_MASONRY_ITEM_ID.lastSongListened}>
  <h3>{t("about.favoriteSong.title")}</h3>

  <FavoriteSongCard />
</FakeMasonryItem>
